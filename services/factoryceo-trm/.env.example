# FactoryCEO-TRM — secrets & endpoints. Edit the values, never commit this file.
# Auto-loaded by src/__init__.py (already-set environment variables take priority).

# --- Inference provider: Fireworks AI (teacher planner + RULER judge) ----------
FIREWORKS_API_KEY=fw_your_fireworks_api_key
# Override the served model if you want a different Fireworks model id:
# FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-31b-it
FIREWORKS_MODEL=accounts/fireworks/models/qwen3p7-plus
FIREWORKS_CHAT_MODEL=accounts/fireworks/models/qwen3p7-plus
# --- Optional: Anthropic (Claude teacher / judge) -----------------------------
ANTHROPIC_API_KEY=

# --- Optional: self-hosted vLLM (only if NOT using Fireworks) ------------------
# VLLM_BASE_URL=http://localhost:8000/v1

# --- Turn on LLM-graded RULER reward (else fast offline heuristic) -------------
# FACTORYCEO_RULER_LLM=1

# --- Hugging Face: used ONLY to host the static Space (not for inference) ------
# Needs a WRITE / "Manage Spaces" token to publish the demo Space.
HF_TOKEN=hf_your_huggingface_write_token

# --- HUD: online grading and TrainingClient RL (preferred path) ---------------
HUD_API_KEY=
# Stronger non-trainable rollout/eval model. Use this for measured HUD tables.
HUD_EVAL_MODEL=claude-opus-4-8
# Trainable gateway model from: hud models list
# HUD_TRAIN_MODEL=shiftbench-qwen36-27b

# --- Fireworks Training API GRPO (slow B200 provisioning; optional fallback) ---
# Profile: 8b (cookbook default) or 27b. Managed cal uses training shape GPU pin.
# FIREWORKS_RL_PROFILE=8b
# FIREWORKS_RL_BASE_MODEL=accounts/<account>/models/your-sft-checkpoint
# FIREWORKS_RL_REWARD_MODE=format
