# Cloudflare Pages — caching + security headers
# (Pages already serves gzip/brotli automatically; these set explicit cache lifetimes.)

# Sensible defaults everywhere
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN

# Hashed build assets are content-addressed → cache hard, forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts & media — long cache
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=2592000
/*.png
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000
/*.mp4
  Cache-Control: public, max-age=2592000
/*.webm
  Cache-Control: public, max-age=2592000

# Discovery files — short cache so edits propagate
/robots.txt
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600

# HTML entry — always revalidate so new deploys are picked up immediately
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
