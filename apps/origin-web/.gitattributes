data/staer-samples/**/*.jpeg   filter=lfs diff=lfs merge=lfs -text
data/staer-samples/**/*.png    filter=lfs diff=lfs merge=lfs -text
factoryceo_trm/results/**/*.jsonl  filter=lfs diff=lfs merge=lfs -text
