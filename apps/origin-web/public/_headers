# Cloudflare Pages — caching + security headers
# (Pages already serves gzip/brotli automatically; these set explicit cache lifetimes.)

# Sensible defaults everywhere
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), camera=(), microphone=(), browsing-topics=()
  # Global CSP. Hardens script/object/base-uri/frame-ancestors while leaving
  # connect/img/media permissive (https:/wss:) so the /app console's InsForge +
  # worker + realtime calls keep working. 'unsafe-inline'/'unsafe-eval' are the
  # pragmatic cost of a static (no-nonce) multi-page bundle.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob:; worker-src 'self' blob:; connect-src 'self' https: wss:

# Hashed build assets are content-addressed → cache hard, forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Homepage stylesheet is versioned via ?v= — safe to cache hard
/home.css
  Cache-Control: public, max-age=31536000, immutable

# Fonts & media — long cache
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=2592000
/*.png
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000
/*.mp4
  Cache-Control: public, max-age=2592000
/*.webm
  Cache-Control: public, max-age=2592000

# Discovery files — short cache so edits propagate
/robots.txt
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600

# HTML entry — always revalidate so new deploys are picked up immediately
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
