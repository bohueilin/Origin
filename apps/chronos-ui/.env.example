# Traceback UI configuration. Copy to `.env` (or set in the Vercel project).
# Both are optional; the defaults below are what ships in production.

# Data source: 'http' (default) reads the real build-time data exported from
# repo artifacts (public/api/*.json); 'mock' uses the in-memory demo dataset.
VITE_TRACEBACK_API=http

# Base path for the static API JSON (default '/api').
VITE_TRACEBACK_API_BASE=/api
