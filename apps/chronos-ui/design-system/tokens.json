{
  "$description": "Granola-style design tokens, machine-readable. Pixel-faithful to granola.ai (see granola-extraction.md). Mirrors tokens.css and tailwind-preset.js.",
  "color": {
    "neutral": {
      "50": "#fcfcf8", "100": "#f7f7f2", "150": "#f2f2ec", "200": "#eaebe5",
      "300": "#d5d5d2", "400": "#acada8", "450": "#9e9e99", "500": "#818179",
      "600": "#72726e", "700": "#4e4d4b", "750": "#363635", "800": "#292929",
      "900": "#212121", "950": "#1e1e1e"
    },
    "green": {
      "50": "#f2f6e1", "100": "#e5eacd", "200": "#d1e043", "300": "#b2c248",
      "400": "#788c15", "500": "#5b6f00", "600": "#434625"
    },
    "red": { "50": "#ffe7e2", "100": "#f8cec5", "200": "#f29e8b", "300": "#e95d3d", "400": "#bd4a30" },
    "semantic": {
      "background": "#ffffff",
      "surface": "#f7f7f2",
      "surface-sunken": "#f2f2ec",
      "surface-raised": "#ffffff",
      "ink-primary": "#292929",
      "ink-secondary": "#72726e",
      "ink-secondary-strong": "#4e4d4b",
      "ink-tertiary": "#acada8",
      "ink-inverse": "#fcfcf8",
      "ink-accent": "#788c15",
      "ink-danger": "#bd4a30",
      "hairline": "#47432a33",
      "stroke": "#d5d5d2",
      "border": "#e3e3e3",
      "accent": "#d1e043",
      "accent-strong": "#b2c248",
      "accent-text": "#0d7916",
      "accent-wash": "#d1e04333",
      "fill-accent": "#5b6f00",
      "fill-accent-hover": "#4c5616",
      "fill-primary": "#292929",
      "fill-primary-hover": "#4e4d4b",
      "fill-danger": "#e95d3d",
      "ring": "#b2c24899",
      "tint-green": "#f2f6e1",
      "tint-blue": "#eaf4fe",
      "tint-purple": "#f3f0fa"
    }
  },
  "font": {
    "family": {
      "display": "\"Inria Serif\", Georgia, serif",
      "sans": "\"Geist\", system-ui, -apple-system, sans-serif",
      "mono": "\"Geist Mono\", ui-monospace, Menlo, monospace"
    },
    "size": {
      "2xs": "11px", "xs": "12px", "sm": "13px", "base": "14px", "lg": "16px",
      "xl": "20px", "2xl": "24px", "3xl": "30px", "4xl": "36px",
      "5xl": "48px", "6xl": "60px", "7xl": "72px"
    },
    "weight": { "light": 300, "normal": 400, "book": 430, "medium": 500, "semibold": 600, "bold": 700 },
    "lineHeight": { "tight": 1.25, "snug": 1.375, "normal": 1.5, "relaxed": 1.625 },
    "letterSpacing": { "tight": "-0.025em", "normal": "0em", "wide": "0.025em", "wider": "0.05em" }
  },
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px",
    "8": "32px", "10": "40px", "12": "48px", "16": "64px", "20": "80px", "24": "96px"
  },
  "radius": {
    "xs": "2px", "sm": "4px", "md": "6px", "lg": "8px", "xl": "12px",
    "2xl": "16px", "3xl": "24px", "full": "9999px", "default": "8px"
  },
  "shadow": {
    "sm": "0px 1px 2px 0px #0000000d",
    "default": "0px 4px 6px -2px #0000000d",
    "lg": "0px 12px 24px -8px #00000014"
  }
}
