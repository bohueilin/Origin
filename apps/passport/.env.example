# Copy this file to .env.local and fill in your values. .env.local is gitignored.
#
# These are SERVER-SIDE ONLY. Do NOT prefix them with VITE_ — that would expose
# them to the browser bundle. They are read by the standalone server (server/main.ts
# via server/config.ts); Vite never reads them, so keys never reach the client.
# In dev, run the backend with `npm run server` and the frontend with `npm run dev`
# (Vite proxies /api and /v1 to the standalone server).

# Standalone gym server (server/main.ts):
# HMAC secret that signs stateless episode tokens. REQUIRED in production
# (NODE_ENV=production); a dev fallback is used if unset. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
EPISODE_SIGNING_SECRET=
# Port for the standalone server (default 8787).
PORT=8787

# REQUIRED to enable Nebius mode. Server-side only.
NEBIUS_API_KEY=

# The model to run as the model-under-test. Server-side only. Examples:
#   meta-llama/Meta-Llama-3.1-70B-Instruct
#   Qwen/Qwen2.5-72B-Instruct
#   deepseek-ai/DeepSeek-V3
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# OPTIONAL. OpenAI-compatible base URL. Configurable — use the sponsor-provided
# endpoint. Defaults to the Nebius Token Factory URL below if unset.
#   Nebius Token Factory:  https://api.tokenfactory.nebius.com/v1
#   Nebius AI Studio:      https://api.studio.nebius.com/v1
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1

# Without these, the app still runs fully — Mock Policy is the default and fallback.

# ---------------------------------------------------------------------------
# InsForge (evidence store) — SERVER-SIDE ONLY. Used by /api/run-episode to
# persist server-authoritative episode traces. Do NOT prefix with VITE_.
# ---------------------------------------------------------------------------

# Your InsForge app base URL, e.g. https://your-app.insforge.app (no trailing /api).
INSFORGE_BASE_URL=

# InsForge API key (the admin/service `ins_...` key). Server-side only — never
# expose this to the browser, and never as a VITE_* var. (The separate anon key is
# not used here; we call InsForge from the server.)
INSFORGE_API_KEY=

# The `eval_episodes` table is migration-managed and RLS-hardened — provision it by
# applying the migrations in migrations/ (do NOT create it by hand):
#   npx @insforge/cli db migrations up --all
# RLS denies direct anon/authenticated access; the server writes/reads evidence
# with its admin credentials. Without these vars, episodes still run server-side
# and the UI shows persistence as "Local only".

# --- Janus v2: the Origin brain + real wallet (server-side only) ---
# GMI Cloud — OpenAI-compatible serverless inference (the agent's brain).
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_MODEL=anthropic/claude-opus-4.8
# Snaplii — real, scoped agent payments. Key from the Snaplii app (snp_sk_live_...).
SNAPLII_API_KEY=
# Optional server-enforced spend ceilings (USD) on top of Snaplii's own daily cap:
# SNAPLII_PER_BUY_CAP_USD=60
# SNAPLII_DAILY_CAP_USD=120
# Set to 1 to make approved buys spend REAL Snaplii Cash (default: simulated).
# SNAPLII_LIVE=1

# --- Enrich-My-Night real execution loop (all server-side, all optional) ---
# Approve-from-phone. ntfy is a FREE, real push with no account: install the ntfy app,
# subscribe to a private topic (any hard-to-guess string), and set it here.
# NTFY_TOPIC=passport-approve-7h2k9q
# NTFY_BASE_URL=https://ntfy.sh
# Optional SMS instead of / in addition to push (Twilio). APPROVAL_PHONE is YOUR number.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1XXXXXXXXXX
# APPROVAL_PHONE=+15089632347
# Publicly reachable base URL (a tunnel) so the phone's "Approve" tap reaches this server.
# Reuse the same tunnel you use for Vapi (cloudflared / ngrok). Without it the push still
# arrives, but you approve in-app.
# PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com

# Discord group message. Create an Incoming Webhook in your server (Channel → Edit →
# Integrations → Webhooks) and paste the URL. Without it the share is simulated.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY
# DISCORD_CHANNEL_LABEL=Game Night

# Order / place context shown in the run (DoorDash has no consumer API, so the order is
# prepared; the Snaplii payment is real). Override the demo defaults here.
# DELIVERY_ADDRESS=123 Market St, San Francisco
# DEMO_ORDER_VENDOR=La Taqueria · DoorDash
# DEMO_ORDER_ITEMS=2 Carne Asada Burritos · Chips & Guac · 2 Mexican Cokes
# DEMO_ORDER_TOTAL_USD=38.50
# DEMO_ORDER_ETA=7:00 PM
# DEMO_GAME_PLAN=Thursday 6:30 PM

# Email the "Agentic Journey Summary" to your own address (Resend; free tier). The recipient is
# SERVER-fixed (never client-chosen), so it can't be an open relay. Without these → simulated preview.
# RESEND_API_KEY=re_xxx
# SUMMARY_EMAIL=you@example.com
# EMAIL_FROM=Janus <onboarding@resend.dev>

# --- 1Password access layer (the credential broker) ---
# A SERVICE ACCOUNT token (ops_...) scoped to a dedicated read-only vault. The token + every secret
# value stay SERVER-SIDE; agents only ever receive opaque, task-scoped lease handles. Resolved at the
# tool boundary via @1password/sdk. Without it, the broker falls back to the in-memory mock.
# OP_SERVICE_ACCOUNT_TOKEN=ops_xxx
# OP_VAULT=Passport
