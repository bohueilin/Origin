# Copy this file to .env.local and fill in your values. .env.local is gitignored.
#
# These are SERVER-SIDE ONLY. Do NOT prefix them with VITE_ — that would expose
# them to the browser bundle. They are read by the standalone server (server/main.ts
# via server/config.ts); Vite never reads them, so keys never reach the client.
# In dev, run the backend with `npm run server` and the frontend with `npm run dev`
# (Vite proxies /api and /v1 to the standalone server).

# Standalone gym server (server/main.ts):
# HMAC secret that signs stateless episode tokens. REQUIRED in production
# (NODE_ENV=production); a dev fallback is used if unset. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
EPISODE_SIGNING_SECRET=
# Port for the standalone server (default 8787).
PORT=8787

# REQUIRED to enable Nebius mode. Server-side only.
NEBIUS_API_KEY=

# The model to run as the model-under-test. Server-side only. Examples:
#   meta-llama/Meta-Llama-3.1-70B-Instruct
#   Qwen/Qwen2.5-72B-Instruct
#   deepseek-ai/DeepSeek-V3
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# OPTIONAL. OpenAI-compatible base URL. Configurable — use the sponsor-provided
# endpoint. Defaults to the Nebius Token Factory URL below if unset.
#   Nebius Token Factory:  https://api.tokenfactory.nebius.com/v1
#   Nebius AI Studio:      https://api.studio.nebius.com/v1
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1

# Without these, the app still runs fully — Mock Policy is the default and fallback.

# ---------------------------------------------------------------------------
# Per-model scorecards (#7) — SERVER-SIDE ONLY, read by the offline eval runner
# hud-env/physical-ai-warehouse/factorydad1/runner.py (NOT by Vite/the browser).
# The runner resolves these from .env.local at the repo root (then ~/.hud/.env).
# ---------------------------------------------------------------------------

# OpenAI (native OpenAI-compatible /chat/completions). Run with --provider openai
# --base-url https://api.openai.com/v1 (api key resolved from OPENAI_API_KEY).
OPENAI_API_KEY=

# Google Gemini via its OpenAI-compatible endpoint. Run with --provider openai
# --api-key-env GEMINI_API_KEY --base-url-env GEMINI_BASE_URL.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ---------------------------------------------------------------------------
# InsForge (evidence store) — SERVER-SIDE ONLY. Used by /api/run-episode to
# persist server-authoritative episode traces. Do NOT prefix with VITE_.
# ---------------------------------------------------------------------------

# Your InsForge app base URL, e.g. https://your-app.insforge.app (no trailing /api).
INSFORGE_BASE_URL=

# InsForge API key (the admin/service `ins_...` key). Server-side only — never
# expose this to the browser, and never as a VITE_* var. (The separate anon key is
# not used here; we call InsForge from the server.)
INSFORGE_API_KEY=

# The `eval_episodes` table is migration-managed and RLS-hardened — provision it by
# applying the migrations in migrations/ (do NOT create it by hand):
#   npx @insforge/cli db migrations up --all
# RLS denies direct anon/authenticated access; the server writes/reads evidence
# with its admin credentials. Without these vars, episodes still run server-side
# and the UI shows persistence as "Local only".

# ---------------------------------------------------------------------------
# FactoryCEO "brain" (optional, self-hosted FastAPI in factoryceo_trm/).
# CLIENT (VITE_, public): origin of the brain for LIVE planning. Leave UNSET on
# the static Cloudflare Pages deploy — the app falls back to the cached floor
# library under public/factoryceo/. Example: VITE_BRAIN_URL=https://origin-brain.fly.dev
VITE_BRAIN_URL=
#
# SERVER-SIDE ONLY (live in factoryceo_trm/.env, gitignored — NEVER VITE_):
#   FIREWORKS_API_KEY=   # teacher planner + RULER judge (Gemma via Fireworks)
#   HUD_API_KEY=         # HUD grading / GRPO training
#   ANTHROPIC_API_KEY=   # optional teacher/judge
#   HF_TOKEN=            # optional: regenerate Staer samples
#   FACTORYCEO_RULER_LLM=1   # optional: LLM-graded soft reward (default off = deterministic)

VITE_INSFORGE_URL=https://<project>.insforge.app
VITE_INSFORGE_ANON_KEY=anon_...
