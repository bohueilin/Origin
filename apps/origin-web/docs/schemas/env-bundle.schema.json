{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://origin-physical-ai.pages.dev/docs/schemas/env-bundle.schema.json",
  "title": "Origin Training Evidence — EnvironmentBundle",
  "description": "A content-addressed lockfile pinning everything that can move a score. env_bundle_digest = sha256(canonical(manifest \\ {created_at, env_bundle_digest})).",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "name",
    "runtime",
    "seed_data",
    "tools",
    "tools_digest",
    "registry_digest",
    "policies",
    "policies_digest",
    "cost_model",
    "rate_digest",
    "verifier",
    "scenario_registry_version",
    "license_policy_version",
    "row_schema_version",
    "reproducibility",
    "env_bundle_digest"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "name": { "type": "string", "minLength": 1 },
    "created_at": {
      "type": "string",
      "description": "Deterministic timestamp. EXCLUDED from env_bundle_digest to avoid round-trip false-mismatch."
    },
    "runtime": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["in_process", "oci", "daytona"], "description": "Execution tier. in_process = Tier-1 gym; oci/daytona = Tier-2 sandboxed (P1)." },
        "code_ref": { "type": "string", "description": "P0 in-process runtime pin (e.g. src/warehouse.ts@warehouse-2026-06-20.1)." },
        "image": { "type": "string", "description": "P1 OCI image digest (sha256:…)." },
        "openenv_spec": { "type": "string", "description": "P1 pinned OpenEnv release." },
        "provider": {
          "type": "object",
          "description": "P4 Tier-2 execution provider (Daytona snapshot/fork/reset). `proven=false` labels a fake whose contract is real but whose container/network isolation is NOT proven (real Daytona is P1).",
          "properties": {
            "name": { "type": "string" },
            "isolation": { "type": "string" },
            "proven": { "type": "boolean" }
          }
        }
      }
    },
    "seed_data": {
      "type": "object",
      "required": ["dataset", "seed_policy"],
      "properties": {
        "dataset": { "type": "string", "description": "sha256 hex of the task/scenario set." },
        "seed_policy": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "description": "Each tool's input schema, content-addressed by schema_digest. Full schemas live in the committed sidecar docs/examples/warehouse.tools.schema.json. scope + rate_limit are added by the MCP tool registry (P3) onto these same entries.",
      "items": {
        "type": "object",
        "required": ["name", "schema_digest", "scope", "rate_limit"],
        "properties": {
          "name": { "type": "string" },
          "schema_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "version": { "type": "string" },
          "scope": { "type": "string", "description": "P3 authorization scope (warehouse.sense|actuate|terminal)." },
          "rate_limit": {
            "type": "object",
            "required": ["capacity", "refill_per_step"],
            "properties": { "capacity": { "type": "integer" }, "refill_per_step": { "type": "number" } }
          }
        }
      }
    },
    "tools_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "sha256(canonical(tools sorted by name)) — the full tool-surface rollup, folded into env_bundle_digest."
    },
    "registry_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "P3: sha256(canonical of the (name, scope, rate_limit) authz projection) — the MCP tool-registry authorization, bound to TOOL_REGISTRY_VERSION."
    },
    "policies": {
      "type": "array",
      "description": "Content-addressed policies (safety gate, license ladder). Each digest binds a human-readable statement to the sha256 of the source code that implements it.",
      "items": {
        "type": "object",
        "required": ["id", "kind", "digest"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "statement": { "type": "string" },
          "source_ref": { "type": "string" },
          "source_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "policies_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "sha256(canonical(policies sorted by id)) — the policy-set rollup, folded into env_bundle_digest."
    },
    "cost_model": {
      "type": "object",
      "description": "P6: pinned cost rates (per the DAYTONA_RATE_VERSION). reward_per_dollar is attribution-only and never feeds the license/safety gate.",
      "required": ["token_in_per_m", "token_out_per_m", "sandbox_usd_per_second", "storage_usd_per_byte"],
      "properties": {
        "rate_version": { "type": "string" },
        "token_in_per_m": { "type": "number" },
        "token_out_per_m": { "type": "number" },
        "sandbox_usd_per_second": { "type": "number" },
        "verifier_usd_per_ms": { "type": "number" },
        "storage_usd_per_byte": { "type": "number" }
      }
    },
    "rate_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "P6: sha256(canonical(cost_model)) — a rate change is a governance event (drift → exit 4)."
    },
    "verifier": {
      "type": "object",
      "required": ["verifier_version", "reward_model_version", "oracle", "reward_spec"],
      "properties": {
        "verifier_version": { "type": "string" },
        "reward_model_version": { "type": "string" },
        "oracle": { "type": "string" },
        "reward_spec": { "type": "string", "description": "sha256 hex of the reward-as-code artifact." }
      }
    },
    "environment_name": { "type": "string" },
    "scenario_registry_version": { "type": "string" },
    "license_policy_version": { "type": "string" },
    "row_schema_version": { "type": "string" },
    "reproducibility": {
      "type": "object",
      "required": ["score", "generation", "recorded_actions_are_authoritative"],
      "properties": {
        "score": { "const": "deterministic-from-recorded-actions" },
        "generation": { "enum": ["best-effort", "pinned"] },
        "recorded_actions_are_authoritative": { "type": "boolean" },
        "canonicalization": { "type": "string" }
      }
    },
    "env_bundle_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Bare sha256 hex. OCI-style sha256: prefix is added at the OCI/ORAS boundary (P1)."
    }
  }
}
