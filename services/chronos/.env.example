# Copy this file to .env for local development.
# Do not commit .env or any file containing real credentials.

# Runtime profile
H2F2H_ENV=local
H2F2H_LOG_LEVEL=INFO
H2F2H_EXTERNAL_DIR=.external
H2F2H_ARTIFACT_DIR=artifacts/forkproof

# HUD
HUD_API_KEY=

# Modal local authentication. Prefer `uv run python -m modal setup` for
# interactive local setup; use these variables for CI/service-user contexts.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_PROFILE=

# LLM provider credentials used by HUD agents and harden-v0/LiteLLM.
# Fill only the provider(s) used by the current run.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Traceback source checkouts
H2F2H_HARDEN_V0_PATH=.external/harden-v0
H2F2H_TERMINAL_WRENCH_PATH=.external/terminal-wrench
H2F2H_TERMINAL_WRENCH_TASK_ID=mongodb-sales-aggregation-engine
H2F2H_TERMINAL_WRENCH_MODEL=claude-opus-4.6

# Discovery defaults. These are non-secret local defaults; plan evidence should
# record the actual values used for each run.
H2F2H_BRANCH_COUNT=12
H2F2H_HACKER_MODEL=
H2F2H_FIXER_MODEL=
H2F2H_SOLVER_MODEL=
H2F2H_SUMMARY_MODEL=

# Modal/Traceback runtime tuning
H2F2H_MODAL_APP_NAME=forkproof
H2F2H_MODAL_CORE_SNAPSHOT_MODE=directory
H2F2H_MODAL_SNAPSHOT_TTL_DAYS=30

# Traceback frontend (Vite) data source. These belong in frontend/.env; see
# frontend/.env.example. 'http' (default) reads real build-time data from
# frontend/public/api/*.json (generated by `uv run python -m forkproof.api.export`);
# 'mock' uses the in-memory demo dataset.
# VITE_FORKPROOF_API=http
# VITE_FORKPROOF_API_BASE=/api
